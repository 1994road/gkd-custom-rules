  "apps": [
    {
      "id": "ctrip.android.view",
      "name": "携程旅行",
      "groups": [
        {
          "key": 0,
          "name": "开屏广告",
          "desc": "自动跳过开屏广告",
          "quickFind": true,
          "matchTime": 10000,
          "actionMaximum": 1,
          "resetMatch": "app",
          "rules": [
            {
              "key": 0,
              "matches": "[text*=\"跳过\"][text.length<10][visibleToUser=true]"
            },
            {
              "key": 1,
              "matches": "[id=\"ctrip.android.view:id/tv_laputa_splash_skip\" || id=\"ctrip.android.view:id/tv_splash_skip\" || text*=\"跳过\" || desc*=\"跳过\"]"
            }
          ]
        }
      ]
    },
